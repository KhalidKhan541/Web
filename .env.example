# ─────────────────────────────────────────
#  AgentAPIs Marketplace — Environment Config
# ─────────────────────────────────────────

# Easypaisa Gateway Settings
# Get these from your Easypaisa merchant account dashboard
EASYPAISA_STORE_ID=12345
EASYPAISA_HASH_KEY=PK_EASYPAISA_SECURE_HASH_KEY_98765
EASYPAISA_SANDBOX_MODE=True   # Set to False for live production payments

# Server Settings
# Set this to your deployed domain (used in payment callback URLs)
BASE_URL=http://127.0.0.1:8000
PORT=8000

# Optional: Secret key for future session signing
SECRET_KEY=change_this_to_a_random_secret_string_in_production
