# ─────────────────────────────────────────
#  AgentAPIs Marketplace — Environment Config
# ─────────────────────────────────────────

# PostgreSQL connection string from Neon (https://neon.tech)
# Get this from: Neon Dashboard → Your Project → Connect → Connection string
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Easypaisa Gateway Settings
EASYPAISA_STORE_ID=12345
EASYPAISA_HASH_KEY=PK_EASYPAISA_SECURE_HASH_KEY_98765
EASYPAISA_SANDBOX_MODE=True

# Set this to your Vercel deployment URL
BASE_URL=https://your-app.vercel.app
